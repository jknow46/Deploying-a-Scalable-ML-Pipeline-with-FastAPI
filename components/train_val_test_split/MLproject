name: train_val_test_split
conda_env: conda.yml

entry_points:
  main:
    parameters:
      input:
        type: string
      test_size:
        type: float
      random_seed:
        type: int
      stratify_by:
        type: string
    command: >
      python run.py
      --input {input}
      --test_size {test_size}
      --random_seed {random_seed}
      --stratify_by {stratify_by}