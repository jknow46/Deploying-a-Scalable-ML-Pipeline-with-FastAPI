name: train_random_forest

conda_env: conda.yml

entry_points:
  main:
    parameters:
      trainval_artifact:
        type: string
      rf_config:
        type: string
      output_artifact:
        type: string
    command: >
      python run.py
      --trainval_artifact {trainval_artifact}
      --rf_config {rf_config}
      --output_artifact {output_artifact}